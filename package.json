{
  "name": "egg-os",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @egg-os/api dev",
    "db:generate": "pnpm --filter @egg-os/db db:generate",
    "db:migrate": "pnpm --filter @egg-os/db db:migrate",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  }
}
